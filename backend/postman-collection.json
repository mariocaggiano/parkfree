    {
      "name": "Analytics",
      "item": [
        {
          "name": "Get Spending Analytics",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_id_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/analytics/spending?period=monthly&months=6",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "spending"],
              "query": [
                {
                  "key": "period",
                  "value": "monthly",
                  "description": "weekly or monthly"
                },
                {
                  "key": "months",
                  "value": "6",
                  "description": "Number of months to include"
                }
              ]
            }
          }
        },
        {
          "name": "Export Sessions as CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{firebase_id_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/analytics/export",
              "host": ["{{base_url}}"],
              "path": ["api", "analytics", "export"]
            }
          }
        }
      ]
    }
