            "url": {
              "raw": "{{base_url}}/api/payments",
              "host": ["{{base_url}}"],
              "path": ["api", "payments"]
            }
          }
        },
        {
          "name": "Create Setup Intent",
          "request": {
            "method": "POST",
            "header": [
